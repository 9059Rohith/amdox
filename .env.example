# =============================================================================
# AMDOX ERP - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL 17 connection string
DATABASE_URL="postgresql://amdox:password@localhost:5432/amdox_erp?schema=public"
# TimescaleDB connection (for audit logs)
TIMESCALE_URL="postgresql://amdox:password@localhost:5432/amdox_timescale?schema=public"

# =============================================================================
# REDIS
# =============================================================================
# Redis 8 connection for sessions, cache, and job queues
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# =============================================================================
# AUTHENTICATION (Keycloak)
# =============================================================================
# Keycloak 25 OIDC configuration
KEYCLOAK_URL="http://localhost:8080"
KEYCLOAK_REALM="amdox-erp"
KEYCLOAK_CLIENT_ID="amdox-api"
KEYCLOAK_CLIENT_SECRET="your-keycloak-client-secret"
# JWT signing key (RS256)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_EXPIRATION="8h"
JWT_REFRESH_EXPIRATION="7d"

# =============================================================================
# ELASTICSEARCH
# =============================================================================
# Elasticsearch 8.15 for full-text search
ELASTICSEARCH_NODE="http://localhost:9200"
ELASTICSEARCH_USERNAME="elastic"
ELASTICSEARCH_PASSWORD="changeme"

# =============================================================================
# EMAIL (AWS SES + Resend fallback)
# =============================================================================
# AWS SES configuration
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_SES_FROM_EMAIL="noreply@amdox.dev"
# Resend fallback
RESEND_API_KEY="re_your_resend_api_key"

# =============================================================================
# AWS SERVICES
# =============================================================================
# AWS Textract for invoice OCR
AWS_TEXTRACT_ENABLED="false"
# S3 for file storage
AWS_S3_BUCKET="amdox-erp-documents"

# =============================================================================
# EXTERNAL APIS
# =============================================================================
# OpenExchangeRates for FX rates (optional - falls back to ECB if not provided)
OPEN_EXCHANGE_RATES_API_KEY=""
# ECB (European Central Bank) is used as fallback - no key required

# =============================================================================
# ML SERVICE
# =============================================================================
# Python FastAPI ML service
ML_SERVICE_URL="http://localhost:8001"
MLFLOW_TRACKING_URI="http://localhost:5000"

# =============================================================================
# OBSERVABILITY
# =============================================================================
# OpenTelemetry configuration
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
OTEL_SERVICE_NAME="amdox-erp-api"
# Jaeger tracing
JAEGER_ENDPOINT="http://localhost:14268/api/traces"
# Prometheus metrics
PROMETHEUS_PORT="9090"

# =============================================================================
# SECURITY
# =============================================================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
# Rate limiting (requests per 15 minutes per IP)
RATE_LIMIT_TTL="900"
RATE_LIMIT_MAX="100"
# Session timeout (in seconds, default 8 hours)
SESSION_TIMEOUT="28800"
# CSRF secret
CSRF_SECRET="your-csrf-secret-min-32-chars-long"

# =============================================================================
# APPLICATION
# =============================================================================
# Node environment
NODE_ENV="development"
# API server
API_PORT="3001"
API_HOST="localhost"
API_URL="http://localhost:3001"
# Web app
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features
FEATURE_OCR_ENABLED="true"
FEATURE_AI_FORECASTING_ENABLED="true"
FEATURE_WEBHOOKS_ENABLED="true"
FEATURE_MFA_ENFORCED="false"

# =============================================================================
# LOGGING
# =============================================================================
# Log level: error, warn, info, debug, trace
LOG_LEVEL="info"
# Loki endpoint for log aggregation
LOKI_URL="http://localhost:3100"

# =============================================================================
# BULL QUEUE (Job Processing)
# =============================================================================
# BullMQ configuration
BULL_BOARD_USERNAME="admin"
BULL_BOARD_PASSWORD="admin@123"

# =============================================================================
# WEBHOOKS
# =============================================================================
# HMAC signature secret for outbound webhooks
WEBHOOK_SECRET="your-webhook-hmac-secret-min-32-chars"

# =============================================================================
# MULTI-TENANCY
# =============================================================================
# Default tenant for seeding
DEFAULT_TENANT_ID="tenant-acme-001"
DEFAULT_TENANT_NAME="Acme Corporation"

# =============================================================================
# TESTING
# =============================================================================
# Test database (separate from development)
TEST_DATABASE_URL="postgresql://amdox:password@localhost:5432/amdox_erp_test?schema=public"
